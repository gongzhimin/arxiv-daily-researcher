{
  // ==================================================
  // Search Configuration
  // ==================================================
  "search_settings": {
    "search_days": 60,
    "max_results": 80,
    "max_results_per_source": {}
  },

  // ==================================================
  // Data Source Configuration
  // ==================================================
  "data_sources": {
    "enabled": [
      "arxiv",
      "prl"
    ],
    "journals": [],
    "reports_by_source": true
  },

  // ==================================================
  // ArXiv Target Domain Configuration
  // ==================================================
  "target_domains": {
    "domains": [
      "cs.AI", "cs.CR", "cs.LG"
    ]
  },

  // ==================================================
  // Keyword Configuration
  // ==================================================
  "keywords": {
    "primary_keywords": {
      "weight": 1.0,
      "keywords": [
        "safety alignment guidelines",    // 安全对齐指南（核心词）
        "SFT safety protocols",            // 有监督微调安全协议
        "safety data curation standards", // 安全数据整理标准
        "red-teaming for fine-tuning",    // 针对微调的红队测试
        "safety refusal training",        // 拒绝回答训练策略
        "jailbreak defense benchmarks",   // 越狱防御基准（用于验证指南有效性）
        "safety-critical fine-tuning"     // 安全关键任务的微调
      ]
    },
    "enable_reference_extraction": true,
    "reference_keywords_config": {
      "max_keywords": 10,
      "similarity_threshold": 0.75,
      "weight_distribution": {
        "high_importance": {
          "weight": 1.0,
          "count": 3
        },
        "medium_importance": {
          "weight": 0.2,
          "count": 5
        },
        "low_importance": {
          "weight": 0.1,
          "count": 2
        }
      }
    },
    "research_context": "我关注生成式大模型在微调阶段的安全性对齐指南（Safety Alignment Guidelines）、如何构建安全微调数据集、企业级模型部署前的安全合规微调流程（SFT protocols）、以及如何通过微调防止模型被诱导产生有害内容。我希望了解最新的行业标准和学术界提出的最佳实践。"
  },

  // ==================================================
  // Scoring Configuration
  // ==================================================
  "scoring_settings": {
    "keyword_relevance_score": {
      "max_score_per_keyword": 10
    },
    "author_bonus": {
      "enabled": false,
      "expert_authors": [],
      "bonus_points": 5.0
    },
    "passing_score_formula": {
      "base_score": 4.0,
      "weight_coefficient": 3.0
    },
    "include_all_in_report": true
  },

  // ==================================================
  // Path Configuration
  // ==================================================
  "paths": {
    "data_dir": "data",
    "reference_pdfs": "data/reference_pdfs",
    "reports": "data/reports",
    "downloaded_pdfs": "data/downloaded_pdfs",
    "history_dir": "data/history"
  },

  // ==================================================
  // Keyword Trend Tracking Configuration
  // ==================================================
  "keyword_tracker": {
    "enabled": true,
    "database": {
      "path": "data/keywords/keywords.db"
    },
    "normalization": {
      "enabled": true,
      "batch_size": 25
    },
    "trend_view": {
      "default_days": 30
    },
    "charts": {
      "bar_chart": {
        "top_n": 15
      },
      "trend_chart": {
        "top_n": 5
      }
    },
    "report": {
      "enabled": true,
      "frequency": "weekly"
    }
  },

  // ==================================================
  // Notification Configuration
  // ==================================================
  "notifications": {
    "enabled": true,
    "on_success": true,
    "on_failure": true,
    "attach_reports": false,
    "top_n": 5,
    "channels": {
      "email": {
        "enabled": false
      },
      "wechat_work": {
        "enabled": true
      },
      "dingtalk": {
        "enabled": false
      },
      "telegram": {
        "enabled": false
      },
      "slack": {
        "enabled": false
      },
      "generic_webhook": {
        "enabled": false
      }
    }
  },

  // ==================================================
  // Retry Configuration
  // ==================================================
  "retry": {
    "max_attempts": 3,
    "min_wait": 2,
    "max_wait": 30
  },

  // ==================================================
  // Logging Configuration
  // ==================================================
  "logging": {
    "rotation_type": "time",
    "keep_days": 30
  },

  // ==================================================
  // Concurrency Configuration
  // ==================================================
  "concurrency": {
    "enabled": true,
    "workers": 2
  },

  // ==================================================
  // PDF Parser Configuration
  // ==================================================
  "pdf_parser": {
    "mode": "mineru",
    "mineru_model_version": "pipeline",
    "poll_interval": 3,
    "poll_timeout": 300
  },

  // ==================================================
  // Report Configuration
  // ==================================================
  "report_settings": {
    "enable_html_report": true
  },

  // ==================================================
  // Auto-update Configuration
  // ==================================================
  "auto_update": {
    "enabled": true
  },

  // ==================================================
  // Token Tracking Configuration
  // ==================================================
  "token_tracking": {
    "enabled": true
  },

  // ==================================================
  // Trend Research Mode Configuration
  // ==================================================
  "trend_research": {
    "default_date_range_days": 365,
    "max_results": 200,
    "sort_order": "ascending",
    "report_position": "end",
    "generate_tldr": true,
    "tldr_batch_size": 10,
    "output_formats": [
      "markdown",
      "html"
    ],
    "enabled_skills": [
      "comprehensive_analysis"
    ]
  }
}
